# ─── Database (this tool's own) ───
DATABASE_URL="file:./prisma/dev.db"

# ─── Staff auth (NextAuth v5 + GitHub OAuth) ───
# Create a GitHub OAuth App at https://github.com/settings/developers
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# ─── Provisioning target ───
# Fine-grained PAT with repo + admin:org + delete_repo on GITHUB_ORG.
# Read only by src/services/GitHubClient.ts. Never commit.
GITHUB_TOKEN=""
GITHUB_ORG=""

# HTTPS URL of the dashboard template repo, or a file:// URL for a local
# bare-repo fixture during dev (run `npm run bootstrap:fixture`).
TEMPLATE_REPO_URL=""
