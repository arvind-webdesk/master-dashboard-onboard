    "prisma:studio": "dotenv -e .env.local -- prisma studio",
    "bootstrap:fixture": "dotenv -e .env.local -- tsx scripts/bootstrap-fixture.ts",
    "provision:cli": "dotenv -e .env.local -- tsx scripts/provision.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "3.9.1",
    "@octokit/rest": "21.0.2",
    "@prisma/client": "5.22.0",
    "next": "15.1.0",
    "next-auth": "5.0.0-beta.25",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "7.53.2",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "22.9.0",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "autoprefixer": "10.4.20",
    "dotenv-cli": "7.4.2",
    "postcss": "8.4.49",
    "prisma": "5.22.0",
    "tailwindcss": "3.4.15",
    "tsx": "4.19.2",
    "typescript": "5.6.3"
  }
